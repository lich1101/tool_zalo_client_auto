# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# macOS Pods generated by `pod install` (covered by macos/.gitignore too,
# kept here so a fresh root scan also skips them).
macos/Pods/
macos/Flutter/ephemeral/

# Note: heavy CEF binaries (framework, libcef_dll_wrapper, cef_helper) are
# already ignored by the package's own .gitignore files at
# packages/webview_cef/{macos,}/third/cef/.gitignore — they are downloaded at
# build time by macos/scripts/download_cef.sh (macOS) and third/download.cmake
# (Windows).
